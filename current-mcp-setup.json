{
    "python.analysis.typeCheckingMode": "standard",
    "chat.mcp.discovery.enabled": true,
    "chat.agent.enabled": true,
    "mcpServers": {
            "miro-mcp": {
                "url": "https://mcp.miro.com/", 
                "disabled": false,
                "autoApprove": []
          }, 
            "cdl": {
                "command": "node",
                "args": ["/Users/clde01/Library/CloudStorage/OneDrive-BetssonGroup/documents/projects/development/mcp/cdl-mcp/dist/index.js"],
                "env": {}
            }, 
            "figma": {
                "url": "http://127.0.0.1:3845/sse",
                "disabled": false,
                "autoApprove": ["get_figma_file", "get_figma_comments"],
                "env": {
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production"
                }
            },
            "atlassian": {
                "command": "npx",
                "args": [
                    "-y",
                    "mcp-remote",
                    "https://mcp.atlassian.com/v1/sse"
                ],
                "disabled": false,
                "autoApprove": ["search_jira", "get_confluence_page"],
                "env": {
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production"
                }
            },
            "aws-documentation": {
                "command": "/Users/clde01/.local/bin/uvx",
                "args": ["awslabs.aws-documentation-mcp-server@latest"],
                "disabled": false,
                "autoApprove": ["search_aws_docs", "get_aws_service_info"],
                "env": {
                    "FASTMCP_LOG_LEVEL": "INFO",
                    "AWS_DOCUMENTATION_PARTITION": "aws",
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production"
                }
            },
            "github": {
                "command": "npx",
                "args": ["-y", "@modelcontextprotocol/server-github"],
                "disabled": false,
                "autoApprove": ["search_repositories", "get_file_contents", "list_repository_contents"],
                "env": {
                    "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}",
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production"
                }
            },
            "terraform": {
                "gallery": true,
                "command": "docker",
                "args": [
                    "run",
                    "-i",
                    "--rm",
                    "--memory=512m",
                    "--cpus=1",
                    "hashicorp/terraform-mcp-server"
                ],
                "disabled": false,
                "autoApprove": ["terraform_plan", "terraform_validate"],
                "env": {
                    "LOG_LEVEL": "INFO",
                    "TF_LOG": "INFO"
                }
            },
            "playwright": {
                "gallery": true,
                "command": "npx",
                "args": [
                    "-y",
                    "@playwright/mcp@latest"
                ],
                "disabled": false,
                "autoApprove": ["screenshot", "get_page_content"],
                "env": {
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production",
                    "PLAYWRIGHT_BROWSERS_PATH": "/tmp/playwright-browsers"
                }
            },
            "filesystem": {
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "/Users/clde01/Library/CloudStorage/OneDrive-BetssonGroup/documents/projects/development/prod-agents"
                ],
                "disabled": false,
                "autoApprove": ["read_file", "list_directory", "search_files"],
                "env": {
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production",
                    "MAX_FILE_SIZE": "10485760",
                    "ALLOWED_EXTENSIONS": ".js,.ts,.tsx,.jsx,.py,.json,.md,.txt,.yaml,.yml,.toml,.env,.gitignore,.dockerfile"
                }
            },
            "web-search": {
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-web-search"
                ],
                "disabled": true,
                "autoApprove": ["search_web"],
                "env": {
                    "LOG_LEVEL": "INFO",
                    "NODE_ENV": "production",
                    "SEARCH_ENGINE": "google",
                    "MAX_RESULTS": "10"
                }
            },
            "aws-document-loader-mcp-server": {
                "command": "uvx",
                "args": ["awslabs.document-loader-mcp-server@latest"],
                "env": {
                    "FASTMCP_LOG_LEVEL": "ERROR"
                },
                "disabled": false,
                "autoApprove": []
            }
    }
}